<?xml version="1.0" encoding="utf-8"?>
<resources>
    
    <style name="BaseTextStyle">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    
    <style name="LargeTextStyle" parent="BaseTextStyle">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
    </style>

    
    <style name="MediumTextStyle" parent="BaseTextStyle">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
    </style>

    
    <style name="SmallTextStyle" parent="BaseTextStyle">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#B3FFFFFF</item>
    </style>
</resources>

